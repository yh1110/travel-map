# Local Supabase (run `npx supabase start`, values from `npx supabase status`)
# On a real device, replace 127.0.0.1 with your Mac's LAN IP (e.g. http://192.168.x.x:54321)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Google Maps API Key
# Obtain from https://console.cloud.google.com/
# Required APIs: Maps SDK for iOS, Maps SDK for Android
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
